{
  "name": "@hap/core",
  "version": "0.4.0",
  "private": true,
  "description": "Thin wrapper — re-exports @humanagencyp/hap-core from npm",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts"
  },
  "dependencies": {
    "@humanagencyp/hap-core": "^0.6.1"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
