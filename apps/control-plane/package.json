{
  "name": "@suveren/control-plane",
  "version": "0.1.0",
  "private": true,
  "description": "Suveren Control Plane — serves UI, proxies AS, handles auth + vault",
  "scripts": {
    "build": "tsup src/index.ts --format esm --outDir dist",
    "start": "node dist/index.mjs",
    "dev": "tsx --watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hpke/core": "^1.9.0",
    "express": "^4.18.0",
    "http-proxy-middleware": "^3.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.10.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
