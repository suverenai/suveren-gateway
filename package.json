{
  "name": "suveren-gateway",
  "version": "0.2.3",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @suveren/ui dev & pnpm --filter @suveren/control-plane dev & pnpm --filter @suveren/mcp-server dev",
    "dev:ui": "pnpm --filter @suveren/ui dev",
    "dev:mcp": "pnpm --filter @suveren/mcp-server dev",
    "dev:control": "pnpm --filter @suveren/control-plane dev",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
